# ============================================
# AI REPORT GENERATOR - Configuration
# ============================================
# IMPORTANT: AI provider keys are SERVER-SIDE only (no VITE_ prefix).
# VITE_* vars are inlined into the browser bundle and would be public.

# ----- Server runtime -----
PORT=7104
NODE_ENV=development

# ============================================
# ZUPER FMS (Server-side proxy)
# ============================================
# Used by the Express backend. The frontend never sees the Zuper key.
ZUPER_API_KEY=your_zuper_api_key
ZUPER_ACCOUNT_REGION=ap-south-1

# ============================================
# FRONTEND-SAFE ZUPER VARS (optional)
# ============================================
# Only set these if some frontend code still reads them. Prefer using
# the backend proxy at /api/jobs and /api/ai instead.
# VITE_ZUPER_API_URL=https://api.zuperpro.com/api/v1
VITE_ZUPER_ACCOUNT_REGION=ap-south-1

# ============================================
# FRONTEND -> BACKEND
# ============================================
# Where the React app sends API requests. Use a relative path in
# production so it hits the same domain Express serves the app from.
VITE_API_URL=/api

# ============================================
# AI PROVIDER (Server-side only - keys NEVER in the browser bundle)
# ============================================
# Supported: ollama, openai, claude, gemini
AI_PROVIDER=openai
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096
AI_TOP_P=0.9

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_URL=https://api.openai.com/v1

# ----- Claude (Anthropic) -----
# CLAUDE_API_KEY=sk-ant-your-claude-key
# CLAUDE_MODEL=claude-3-5-sonnet-latest

# ----- Gemini (Google) -----
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-1.5-flash

# ----- Ollama (local) -----
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3-vl:4b
