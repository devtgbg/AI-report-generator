# ============================================
# ZUPER AI REPORT GENERATOR - Configuration
# ============================================

# Zuper FMS API
VITE_ZUPER_API_URL=https://api.zuperpro.com/api/v1
VITE_ZUPER_API_KEY=your_zuper_api_key
VITE_ZUPER_ACCOUNT_REGION=ap-south-1

# ============================================
# AI PROVIDER CONFIGURATION
# ============================================
# Supported providers: ollama, openai, claude, gemini
VITE_AI_PROVIDER=ollama

# Generation Parameters (applies to all providers)
VITE_AI_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=4096
VITE_AI_TOP_P=0.9

# ============================================
# OLLAMA (Local AI - Default)
# ============================================
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=qwen3-vl:4b
# Other options: llama3.2:7b, gemma2:9b, mistral:7b

# ============================================
# OPENAI
# ============================================
# VITE_AI_PROVIDER=openai
# VITE_OPENAI_API_KEY=sk-your-openai-api-key
# VITE_OPENAI_MODEL=gpt-4o-mini
# Other options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# ============================================
# CLAUDE (Anthropic)
# ============================================
# VITE_AI_PROVIDER=claude
# VITE_CLAUDE_API_KEY=sk-ant-your-claude-api-key
# VITE_CLAUDE_MODEL=claude-3-5-sonnet-latest
# Other options: claude-3-opus-latest, claude-3-haiku-20240307

# ============================================
# GEMINI (Google)
# ============================================
# VITE_AI_PROVIDER=gemini
# VITE_GEMINI_API_KEY=your-gemini-api-key
# VITE_GEMINI_MODEL=gemini-1.5-flash
# Other options: gemini-1.5-pro, gemini-2.0-flash
